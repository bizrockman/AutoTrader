# Binance API
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET=your_binance_secret

# LLM API Keys (LiteLLM supports multiple providers)
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key

# Default LLM model for strategy generation
DEFAULT_MODEL=claude-opus-4-6

# Model pool for evolution (comma-separated)
MODEL_POOL=claude-opus-4-6,claude-sonnet-4-6,gpt-5.4

# Paper Trading
INITIAL_BALANCE=10000
TRADING_FEE_PCT=0.1
DEFAULT_SYMBOL=BTC/USDT

# Execution Reality Modeling (Track A)
SLIPPAGE_PCT=0.01
MIN_NOTIONAL=5.0
TICK_SIZE=0.01
STEP_SIZE=0.00001
MAKER_FEE_PCT=0.1
TAKER_FEE_PCT=0.1
# FILL_DELAY_MS=0

# Risk Governance (Track B)
# MAX_NOTIONAL_PER_STRATEGY=5000
# MAX_PORTFOLIO_EXPOSURE=0.9
# MAX_DAILY_LOSS_PCT=5.0
# MAX_DRAWDOWN_PCT=10.0
# MAX_CONSECUTIVE_LOSSES=5
# COOLDOWN_MINUTES=30

# Evolution
MAX_PARALLEL_STRATEGIES=5
